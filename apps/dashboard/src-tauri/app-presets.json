  {
    "type": "phpstorm",
    "bundleId": "com.jetbrains.PhpStorm",
    "displayName": "PhpStorm",
    "launchCommand": "open -a \"PhpStorm\" \"{{path}}\"",
    "titleHint": "{{folder}}",
    "waitTimeout": 30000
  }
