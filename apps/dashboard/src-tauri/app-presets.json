[
  {
    "type": "vscode",
    "bundleId": "com.microsoft.VSCode",
    "displayName": "Visual Studio Code",
    "launchCommand": "open -a \"Visual Studio Code\" \"{{path}}\"",
    "titleHint": "{{folder}}"
  },
  {
    "type": "cursor",
    "bundleId": "com.todesktop.230313mzl4w4u92",
    "displayName": "Cursor",
    "launchCommand": "open -a \"Cursor\" \"{{path}}\"",
    "titleHint": "{{folder}}"
  },
  {
    "type": "zed",
    "bundleId": "dev.zed.Zed",
    "displayName": "Zed",
    "launchCommand": "open -a \"Zed\" \"{{path}}\"",
    "titleHint": "{{folder}}"
  },
  {
    "type": "iterm",
    "bundleId": "com.googlecode.iterm2",
    "displayName": "iTerm2",
    "launchCommand": "open -a \"iTerm\"",
    "newWindowCommand": "osascript -e 'tell application \"iTerm2\" to create window with default profile'",
    "setupCommand": "$HOME/.band/scripts/iterm-setup.py \"{{path}}\" \"{{folder}}\"",
    "titleHint": "band:{{folder}}"
  },
  {
    "type": "chrome",
    "bundleId": "com.google.Chrome",
    "displayName": "Google Chrome",
    "launchCommand": "$HOME/.band/scripts/chrome-launch.py"
  },
  {
    "type": "xcode",
    "bundleId": "com.apple.dt.Xcode",
    "displayName": "Xcode",
    "launchCommand": "$HOME/.band/scripts/xcode-launch.py \"{{path}}\"",
    "titleHint": "{{folder}}"
  },
  {
    "type": "intellij",
    "bundleId": "com.jetbrains.intellij",
    "displayName": "IntelliJ IDEA",
    "launchCommand": "open -a \"IntelliJ IDEA\" \"{{path}}\"",
    "titleHint": "{{folder}}",
    "waitTimeout": 30000
  },
  {
    "type": "webstorm",
    "bundleId": "com.jetbrains.WebStorm",
    "displayName": "WebStorm",
    "launchCommand": "open -a \"WebStorm\" \"{{path}}\"",
    "titleHint": "{{folder}}",
    "waitTimeout": 30000
  },
  {
    "type": "pycharm",
    "bundleId": "com.jetbrains.pycharm",
    "displayName": "PyCharm",
    "launchCommand": "open -a \"PyCharm\" \"{{path}}\"",
    "titleHint": "{{folder}}",
    "waitTimeout": 30000
  },
  {
    "type": "goland",
    "bundleId": "com.jetbrains.goland",
    "displayName": "GoLand",
    "launchCommand": "open -a \"GoLand\" \"{{path}}\"",
    "titleHint": "{{folder}}",
    "waitTimeout": 30000
  },
  {
    "type": "rider",
    "bundleId": "com.jetbrains.rider",
    "displayName": "Rider",
    "launchCommand": "open -a \"Rider\" \"{{path}}\"",
    "titleHint": "{{folder}}",
    "waitTimeout": 30000
  },
  {
    "type": "clion",
    "bundleId": "com.jetbrains.CLion",
    "displayName": "CLion",
    "launchCommand": "open -a \"CLion\" \"{{path}}\"",
    "titleHint": "{{folder}}",
    "waitTimeout": 30000
  },
  {
    "type": "rustrover",
    "bundleId": "com.jetbrains.rustrover",
    "displayName": "RustRover",
