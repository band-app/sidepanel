{
  "$schema": "https://raw.githubusercontent.com/nicegui/nicegui/main/nicegui/static/tauri.conf.schema.json",
  "productName": "Band",
  "version": "0.1.0",
  "identifier": "com.band.dashboard",
  "build": {
    "frontendDist": "http://localhost:3456",
    "devUrl": "http://localhost:3456",
    "beforeDevCommand": "pnpm -w dev:web",
    "beforeBuildCommand": "pnpm -w build:web && pnpm build && pnpm -w build:cli && pnpm -w build:extension"
  },
  "app": {
    "windows": [
      {
        "title": "Band",
        "width": 400,
        "minWidth": 240,
        "height": 900,
        "x": 0,
        "y": 0,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 13, "y": 16 },
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg"],
    "externalBin": ["binaries/band"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../../web/dist/": "web/dist/",
      "../../../extensions/vscode/dist/extension.js": "extensions/band/dist/extension.js",
      "../../../extensions/vscode/package.json": "extensions/band/package.json"
    }
  },
  "plugins": {}
}
