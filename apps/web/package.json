{
  "name": "@band-app/server",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "band-server": "./bin/band-server.mjs"
  },
  "files": [
    "dist/client",
    "dist/server",
    "dist/start-server.mjs",
    "dist/migrations",
    "bin"
  ],
  "engines": {
    "node": ">=22"
  },
  "os": [
    "darwin",
    "linux"
  ],
  "scripts": {
    "dev": "vite dev --port 3456 --host 0.0.0.0",
    "build": "vite build && ./scripts/build-server.sh",
    "start": "node dist/start-server.mjs",
    "build:test-server": "esbuild test-server.ts --bundle --platform=node --format=esm --outfile=dist/test-server.mjs --banner:js=\"import{createRequire as __cr}from'module';import{fileURLToPath as __fu}from'url';import{dirname as __dn}from'path';const require=__cr(import.meta.url);const __filename=__fu(import.meta.url);const __dirname=__dn(__filename);\"",
    "pretest": "pnpm build",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "postinstall": "chmod +x node_modules/node-pty/prebuilds/*/spawn-helper 2>/dev/null || true"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "node-pty": "^1.1.0"
  },
  "devDependencies": {
    "@ai-sdk/react": "^3.0.0",
    "@band-app/coding-agent": "workspace:^",
    "@band-app/dashboard-core": "workspace:^",
    "@band-app/logger": "workspace:^",
    "@band-app/ui": "workspace:^",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@playwright/test": "^1.58.2",
    "@streamdown/cjk": "^1.0.2",
    "@streamdown/code": "^1.0.3",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "@tailwindcss/vite": "^4.0.0",
    "@tanstack/react-router": "^1.154.0",
    "@tanstack/react-start": "^1.154.0",
    "@tanstack/router-plugin": "^1.154.0",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-shell": "^2.0.0",
    "@trpc/client": "^11.12.0",
    "@trpc/openapi": "11.16.0-alpha",
    "@trpc/server": "^11.12.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.19.13",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.18.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "ai": "^6.0.105",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "croner": "^10.0.1",
    "drizzle-kit": "^0.31.9",
    "drizzle-orm": "^0.45.1",
    "esbuild": "^0.25.0",
    "lucide-react": "^0.576.0",
    "nanoid": "^5.1.6",
    "qrcode.react": "^4.2.0",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sirv": "^3.0.0",
    "streamdown": "^2.3.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.0.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.7.0",
    "use-stick-to-bottom": "^1.1.3",
    "vite": "^7.0.0",
    "vitest": "^4.0.18",
    "ws": "^8.18.0",
    "zod": "^3.25.67"
  }
}
