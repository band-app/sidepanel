{
  "name": "sidepanel",
  "version": "0.1.0",
  "private": true,
  "description": "Sidepanel — macOS launcher for projects and git worktrees",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:extension": "esbuild extensions/vscode/src/extension.ts --bundle --outfile=extensions/vscode/dist/extension.js --external:vscode --format=cjs --platform=node",
    "build:all": "pnpm build && pnpm build:extension",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "lint": "biome check . && cargo clippy --manifest-path src-tauri/Cargo.toml -- -D warnings",
    "lint:fix": "biome check --fix . && cargo clippy --manifest-path src-tauri/Cargo.toml --fix --allow-dirty",
    "format": "biome format . && cargo fmt --manifest-path src-tauri/Cargo.toml -- --check",
    "format:fix": "biome format --fix . && cargo fmt --manifest-path src-tauri/Cargo.toml",
    "check": "biome check . && cargo fmt --manifest-path src-tauri/Cargo.toml -- --check && cargo clippy --manifest-path src-tauri/Cargo.toml -- -D warnings",
    "test": "cargo test --manifest-path src-tauri/Cargo.toml",
    "prepare": "husky"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "@tailwindcss/vite": "^4.2.4",
    "@tauri-apps/cli": "^2.1.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/vscode": "^1.85.0",
    "@vitejs/plugin-react": "^5.0.0",
    "esbuild": "^0.24.0",
    "husky": "^9.1.7",
    "tailwindcss": "^4.2.4",
    "typescript": "~5.6.0",
    "vite": "^6.0.0"
  }
}
