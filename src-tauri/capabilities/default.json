{
  "identifier": "default",
  "description": "Default permissions for Sidepanel",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:webview:default",
    "core:window:default",
    "core:window:allow-start-dragging",
    "core:window:allow-set-position",
    "core:window:allow-set-size",
    "core:event:default",
    "fs:default",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-read-dir",
    "shell:default",
    "shell:allow-open",
    "dialog:default",
    "dialog:allow-open"
  ]
}
