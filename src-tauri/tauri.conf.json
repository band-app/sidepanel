{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sidepanel",
  "version": "0.1.0",
  "identifier": "com.band-app.sidepanel",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build && pnpm build:extension"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Sidepanel",
        "width": 320,
        "minWidth": 240,
        "height": 900,
        "x": 0,
        "y": 0,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 13, "y": 17 },
        "dragDropEnabled": false
      },
      {
        "label": "settings",
        "title": "Settings",
        "width": 760,
        "height": 640,
        "minWidth": 560,
        "minHeight": 420,
        "resizable": true,
        "visible": false,
        "focus": false,
        "skipTaskbar": false,
        "decorations": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../extensions/vscode/dist/extension.js": "extensions/sidepanel/dist/extension.js",
      "../extensions/vscode/package.json": "extensions/sidepanel/package.json"
    }
  },
  "plugins": {}
}
